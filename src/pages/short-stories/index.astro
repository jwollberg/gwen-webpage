---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { mediaPath } from "../../lib/paths";

const storiesBackground = "/media/images/shoreline-notebook.png";
---

<SiteLayout
  title="Short Stories | Gwen"
  description="Short fiction by Gwenevere Ivy Greenwood."
>
  <section
    class="fixed-photo-page quiet-page"
    style={`--page-image: url('${mediaPath(storiesBackground)}')`}
  >
    <div class="quiet-shell">
      <p class="quiet-label">Short Stories</p>
      <h1>Under construction</h1>
      <p>
        Short stories are currently being prepared and submitted for
        publication. Once they appear in magazines or journals, this page will
        gather links to those published pieces instead of posting the full
        stories here.
      </p>
    </div>
  </section>
</SiteLayout>
