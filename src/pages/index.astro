---
import EditablePageIntro from "../components/EditablePageIntro.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { getPageSettings } from "../lib/settings";

const homeSettings = await getPageSettings("home");
---

<SiteLayout
  title="Gwenevere Ivy Greenwood"
  description="The personal poetry, short fiction, and artwork website of Gwenevere Ivy Greenwood."
  bodyClass="home-body"
>
  <EditablePageIntro settings={homeSettings} titleId="about-title" className="home-page" />
</SiteLayout>
