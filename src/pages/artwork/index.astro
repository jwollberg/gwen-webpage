---
import EditablePageIntro from "../../components/EditablePageIntro.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { mediaPath } from "../../lib/paths";
import { getPageSettings } from "../../lib/settings";

const artworkSettings = await getPageSettings("artwork");
---

<SiteLayout
  title="Artwork | Gwen"
  description="A developing visual archive for Gwen's photography, drawings, and mixed media artwork."
>
  <EditablePageIntro settings={artworkSettings} titleId="artwork-title" className="artwork-page">
    <div class="artwork-strip" aria-label="Artwork preview images">
      {
        artworkSettings.images.map((item) => (
          <figure>
            <img src={mediaPath(item.image)} alt={item.alt} loading="lazy" />
          </figure>
        ))
      }
    </div>
  </EditablePageIntro>
</SiteLayout>
