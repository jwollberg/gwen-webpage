---
import EditablePageIntro from "../../components/EditablePageIntro.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { brightnessPercent } from "../../lib/images";
import { mediaPath } from "../../lib/paths";
import { getPageSettings } from "../../lib/settings";

const photographySettings = await getPageSettings("photography");
---

<SiteLayout
  title="Photography | Gwen"
  description="A developing photography archive by Gwenevere Ivy Greenwood."
>
  <EditablePageIntro
    settings={photographySettings}
    titleId="photography-title"
    className="artwork-page photography-page"
  >
    <div class="artwork-strip" aria-label="Photography preview images">
      {
        photographySettings.images.map((item) => (
          <figure style={`--image-brightness: ${brightnessPercent(item.brightness)}`}>
            <img src={mediaPath(item.image)} alt={item.alt} loading="lazy" />
          </figure>
        ))
      }
    </div>
  </EditablePageIntro>
</SiteLayout>
