---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { categories, getAdjacentPoems, getPoemPath } from "../../../lib/poems";
import { mediaPath } from "../../../lib/paths";

export function getStaticPaths() {
  return categories.flatMap((category) =>
    category.poems.map((poem) => ({
      params: { category: category.slug, slug: poem.slug },
      props: { category, poem },
    })),
  );
}

const { category, poem } = Astro.props;
const { previous, next } = getAdjacentPoems(poem.slug, category.slug);
const Content = poem.Content;
---

<SiteLayout
  title={`${poem.title} | Gwenevere Ivy Greenwood`}
  description={`${poem.title} by Gwenevere Ivy Greenwood.`}
  bodyClass="reader-body"
>
  <article class="reader">
    <div class="reader-shell">
      <header class="reader-title">
        <p class="meta">{category.title}</p>
        <h1>{poem.title}</h1>
      </header>

      {
        poem.image && (
          <figure class="reader-photo">
            <img src={mediaPath(poem.image)} alt="" />
          </figure>
        )
      }

      <div class="reader-panel" aria-label={`${poem.title} poem text`}>
        <div class="reader-panel-inner poem-body">
          <Content />
        </div>
        {
          poem.music && (
            <div class="audio-dock">
              <audio controls src={mediaPath(poem.music)} preload="metadata">
                <a href={mediaPath(poem.music)}>Download audio</a>
              </audio>
            </div>
          )
        }
      </div>

      {
        (previous || next) && (
          <nav class="reader-pager" aria-label="More poems">
            <div>
              {previous && (
                <a class="button secondary" href={getPoemPath(previous)}>
                  ← Previous
                </a>
              )}
            </div>
            <div>
              {next && (
                <a class="button secondary" href={getPoemPath(next)}>
                  Next →
                </a>
              )}
            </div>
          </nav>
        )
      }
    </div>
  </article>
</SiteLayout>
