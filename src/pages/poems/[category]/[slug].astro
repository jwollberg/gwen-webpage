---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  categories,
  getAdjacentPoems,
  getCategoryPath,
  getPoemPath,
} from "../../../lib/poems";
import { brightnessPercent, textColorValue } from "../../../lib/images";
import { mediaPath, sitePath } from "../../../lib/paths";

export function getStaticPaths() {
  return categories.flatMap((category) =>
    category.poems.map((poem) => ({
      params: { category: category.slug, slug: poem.slug },
      props: { category, poem },
    })),
  );
}

const { category, poem } = Astro.props;
const { previous, next } = getAdjacentPoems(poem.slug, category.slug);
const Content = poem.Content;
const readerStyle = [
  `--reader-image: ${poem.image ? `url('${mediaPath(poem.image)}')` : "none"}`,
  `--reader-bg-brightness: ${brightnessPercent(poem.imageBrightness)}`,
  `--reader-text-color: ${textColorValue(poem.textColor)}`,
].join("; ");
---

<SiteLayout
  title={`${poem.title} | Gwen`}
  description={`${poem.title} by Gwenevere Ivy Greenwood.`}
  bodyClass="reader-body"
>
  <article class="reader" style={readerStyle}>
    <div class="reader-shell">
      <header class="reader-title">
        <p class="meta">{category.title}</p>
        <h1>{poem.title}</h1>
        <div class="reader-nav">
          <a class="button secondary" href={getCategoryPath(category)}>Category</a>
          <a class="button secondary" href={sitePath("/poems/")}>All poems</a>
          {previous && <a class="button secondary" href={getPoemPath(previous)}>Newer</a>}
          {next && <a class="button secondary" href={getPoemPath(next)}>Older</a>}
        </div>
      </header>

      <div class="reader-panel" aria-label={`${poem.title} poem text`}>
        <div class="reader-panel-inner poem-body">
          <Content />
        </div>
        {
          poem.music && (
            <div class="audio-dock">
              <audio controls src={mediaPath(poem.music)} preload="metadata">
                <a href={mediaPath(poem.music)}>Download audio</a>
              </audio>
            </div>
          )
        }
      </div>
    </div>
  </article>
</SiteLayout>
