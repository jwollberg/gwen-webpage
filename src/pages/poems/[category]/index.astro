---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  categories,
  getPoemPath,
  getPoemsByCategory,
} from "../../../lib/poems";
import { mediaPath } from "../../../lib/paths";

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const categoryPoems = getPoemsByCategory(category.slug);
---

<SiteLayout
  title={`${category.title} Poems | Gwen`}
  description={`${category.title} poems by Gwenevere Ivy Greenwood.`}
>
  <section
    class="page-hero category-hero"
    style={category.image ? `background-image: url('${mediaPath(category.image)}')` : ""}
  >
    <h1>{category.title}</h1>
  </section>
  <section class="section dark" aria-label={`${category.title} poems`}>
    <div class="poem-grid">
    {
      categoryPoems.map((poem) => (
        <a class:list={["poem-card", !poem.image && "poem-card-no-image"]} href={getPoemPath(poem)}>
          {poem.image && <img src={mediaPath(poem.image)} alt="" loading="lazy" />}
          <div>
            <h3>{poem.title}</h3>
            {poem.tags && (
              <div class="tags" aria-label="Tags">
                {poem.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))
    }
    </div>
  </section>
</SiteLayout>
