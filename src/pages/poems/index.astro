---
import EditablePageIntro from "../../components/EditablePageIntro.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { categories } from "../../lib/poems";
import { getPageSettings } from "../../lib/settings";

const poetrySettings = await getPageSettings("poetry");
const poetryCollections = categories.filter((category) => category.poems.length > 0);
---

<SiteLayout title="Poetry | Gwen" description="Read Gwen's poems in place.">
  <EditablePageIntro settings={poetrySettings} titleId="poetry-title" className="poetry-page">
    <div class="collection-list" aria-label="Poetry collections">
      {
        poetryCollections.map((category) => (
          <section class="poetry-collection" aria-labelledby={`${category.slug}-title`}>
            <div class="collection-heading">
              <h2 id={`${category.slug}-title`}>{category.title}</h2>
            </div>

            <div class="poem-accordion">
              {
                category.poems.map((poem) => {
                  const Content = poem.Content;

                  return (
                    <details class="poem-disclosure">
                      <summary>
                        <span>
                          <strong>{poem.title}</strong>
                        </span>
                        <span class="summary-mark" aria-hidden="true">
                          <span class="open-label">Open</span>
                          <span class="close-label">Close</span>
                        </span>
                      </summary>
                      <div class="inline-poem">
                        <div class="poem-body">
                          <Content />
                        </div>
                      </div>
                    </details>
                  );
                })
              }
            </div>
          </section>
        ))
      }
    </div>
  </EditablePageIntro>
</SiteLayout>
