---
import "../styles/global.css";
import { sitePath } from "../lib/paths";

type Props = {
  title?: string;
  description?: string;
  bodyClass?: string;
};

const {
  title = "Gwenevere Ivy Greenwood",
  description = "A personal home for Gwenevere Ivy Greenwood's poetry, short fiction, and artwork.",
  bodyClass = "",
} = Astro.props;

const navItems = [
  { href: "/poems/", label: "Poetry" },
  { href: "/short-stories/", label: "Short Stories" },
  { href: "/artwork/", label: "Artwork" },
  { href: "/photography/", label: "Photography" },
];

const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f2ec" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <a
      class="absolute left-4 -top-40 z-[100] bg-ink px-4 py-3 text-paper focus:top-4"
      href="#main"
    >
      Skip to content
    </a>
    <header
      class="sticky top-0 z-50 flex flex-col items-center gap-[0.85rem] border-b border-line bg-[color-mix(in_srgb,var(--color-paper)_88%,transparent)] px-[var(--edge)] py-[1.15rem] text-center backdrop-blur-[10px]"
    >
      <a
        class="font-display text-[clamp(1.6rem,3.5vw,2.2rem)] font-medium tracking-[0.01em] text-ink"
        href={sitePath("/")}
        aria-label="Gwenevere Ivy Greenwood home"
      >
        Gwenevere Ivy Greenwood
      </a>
      <nav
        class="flex flex-wrap justify-center gap-8 max-[560px]:gap-x-5 max-[560px]:gap-y-[1.1rem]"
        aria-label="Main navigation"
      >
        {
          navItems.map((item) => (
            <a
              href={sitePath(item.href)}
              class:list={[
                "border-b border-transparent pb-0.5 text-[0.86rem] tracking-[0.04em] text-ink-soft transition-[color,border-color] duration-200 ease-[ease] hover:border-accent hover:text-ink focus-visible:border-accent focus-visible:text-ink",
                { "!border-accent !text-ink": isActive(item.href) },
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="border-t border-line bg-paper-2 px-[var(--edge)] py-10">
      <p class="m-0 font-display text-[1.3rem] text-ink">Gwenevere Ivy Greenwood</p>
      <p class="mt-[0.4rem] text-[0.85rem] text-ink-soft">
        Poetry, short fiction, and artwork.
      </p>
    </footer>
  </body>
</html>
